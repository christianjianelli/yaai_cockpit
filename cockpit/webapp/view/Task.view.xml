<mvc:View controllerName="aaic.cockpit.controller.Task"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:form="sap.ui.layout.form"
    xmlns="sap.m">
    <f:DynamicPage id="_IDTaskDynamicPage" showFooter="true">
        <f:title>
            <f:DynamicPageTitle id="_IDTaskDynamicPageTitle">
                <f:heading>
                    <Title id="_IDTaskTitle" text="{i18n>task}"/>
                </f:heading>
                <f:breadcrumbs>
                    <Breadcrumbs id="_IDTaskBreadcrumbs" currentLocationText="{i18n>task}">
                        <Link id="_IDTaskLinkHome" text="{i18n>home}" press=".onNavBackMaster('RouteMain')"/>
                        <Link id="_IDTaskLinkTasks" text="{i18n>tasks}" press=".onNavBackMaster('RouteTasks')"/>
                    </Breadcrumbs>
                </f:breadcrumbs>
                <f:actions>
                    <Button id="_IDTaskButtonEdit" class="sapUiTinyMarginEnd" type="Default" icon="sap-icon://edit" text="{i18n>edit}" press=".onToogleEdit"/>
                    <Button id="_IDTaskButtonSave" class="sapUiTinyMarginEnd" type="Emphasized" icon="sap-icon://save" text="{i18n>save}" enabled="false" press=".onSave"/>
                </f:actions>
                <f:navigationActions>
                    <Button
                        id="_IDTaskNavBack"
                        icon="sap-icon://nav-back"
                        type="Transparent"
                        text="{i18n>tasks}" 
                        press=".onNavBackMaster('RouteTasks')"/>
                    <Button
                        id="_IDTaskNavHome"
                        icon="sap-icon://home"
                        tooltip="{i18n>home}"
                        type="Transparent" 
                        press=".onNavBackMaster('RouteMain')"/>    
                </f:navigationActions>
            </f:DynamicPageTitle>
        </f:title>
        <f:content>
            <Panel id="_IDTaskModelsPanel" width="auto" headerText="{i18n>taskInfo}" class="sapUiResponsiveMargin" expandable="false">
                <content>
                    <form:Form id="_IDTaskForm" editable="true">
                        <form:layout>
                            <form:ColumnLayout id="_IDTaskColumnLayout" 
                                columnsM="1"
                                columnsL="3"
                                columnsXL="3"
                            />
                        </form:layout>
                        <form:formContainers>
                            <form:FormContainer id="_IDTaskFormContainer">
                                <form:formElements>
                                    <form:FormElement id="_IDTaskFormElementId" label="{i18n>id}">
                                        <form:fields>
                                            <Input
                                                id="_IDTaskIdInput"
                                                type="Text"
                                                editable="false"
                                                value="{tasks>id}">
                                            </Input>
                                        </form:fields>
                                    </form:FormElement>
                                    <form:FormElement id="_IDTaskFormElementName" label="{i18n>name}">
                                        <form:fields>
                                            <Input
                                                id="_IDTaskNameInput"
                                                type="Text"
                                                editable="false"
                                                maxLength="30"
                                                value="{tasks>name}">
                                            </Input>
                                        </form:fields>
                                    </form:FormElement>
                                    <form:FormElement id="_IDTaskFormElementTaskDescription" label="{i18n>description}">
                                        <form:fields>
                                            <Input
                                                id="_IDTaskDescriptionInput"
                                                type="Text"
                                                editable="false"
                                                value="{tasks>description}">
                                            </Input>
                                        </form:fields>
                                    </form:FormElement>
                                </form:formElements>
                            </form:FormContainer>
                        </form:formContainers>
                    </form:Form>
                </content>
	        </Panel>
        </f:content>
        <f:footer>
			<OverflowToolbar id="_IDTaskPageFooter" class="sapUiSmallMarginBottom">
                <Button id="_IDTaskMessagePopoverButton"
					icon="sap-icon://alert"
					text="{=${message>/}.length}"
					visible="{=${message>/}.length > 0}"
					type="Transparent"
					press=".onMessagePopoverPress"/>
                <ToolbarSpacer id="_IDTaskToolbarSpacerBegin"/>
			</OverflowToolbar>
		</f:footer>
	</f:DynamicPage>
</mvc:View>