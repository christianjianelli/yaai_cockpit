<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:l="sap.ui.layout"
	xmlns:u="sap.ui.unified">
	<Dialog
		id="_IDAddTaskDialog"
		title="{i18n>addTask}"
		class="sapUiContentPadding">
		<content>
			<l:VerticalLayout id="_IDAddTaskVerticalLayout">
				<Label 
					id="_IDAddTaskLabelName" 
					labelFor="_IDAddTaskInputName" 
					text="{i18n>name}">
				</Label>
				<Input
					id="_IDAddTaskInputName"
					type="Text"
					width="20em"
					editable="true">
				</Input>
				<Label 
					id="_IDAddTaskLabelDescription" 
					labelFor="_IDAddTaskInputDescription" 
					text="{i18n>description}">
				</Label>
				<Input
					id="_IDAddTaskInputDescription"
					type="Text"
					width="20em"
					editable="true">
				</Input>
			</l:VerticalLayout>
		</content>
		<buttons>        
            <Button id="_IDAddTaskButtonAdd" press=".onAddTask" text="{i18n>add}"/>
			<Button id="_IDAddTaskButtonCancel" press=".onCloseDialog" text="{i18n>cancel}"/>
        </buttons>
	</Dialog>
</core:FragmentDefinition>