<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:l="sap.ui.layout"
	xmlns:u="sap.ui.unified">
	<Dialog
		id="_IDAddTaskflowDialog"
		title="{i18n>addTaskflow}"
		class="sapUiContentPadding">
		<content>
			<l:VerticalLayout id="_IDAddTaskflowVerticalLayout">
				<Label 
					id="_IDAddTaskflowLabelName" 
					labelFor="_IDAddTaskflowInputName" 
					text="{i18n>name}">
				</Label>
				<Input
					id="_IDAddTaskflowInputName"
					type="Text"
					width="20em"
					editable="true">
				</Input>
				<Label 
					id="_IDAddTaskflowLabelDescription" 
					labelFor="_IDAddTaskflowInputDescription" 
					text="{i18n>description}">
				</Label>
				<Input
					id="_IDAddTaskflowInputDescription"
					type="Text"
					width="20em"
					editable="true">
				</Input>
			</l:VerticalLayout>
		</content>
		<buttons>        
            <Button id="_IDAddTaskflowButtonAdd" press=".onAddTaskflow" text="{i18n>add}"/>
			<Button id="_IDAddTaskflowButtonCancel" press=".onCloseDialog" text="{i18n>cancel}"/>
        </buttons>
	</Dialog>
</core:FragmentDefinition>